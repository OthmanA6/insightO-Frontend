            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Student\",\n  \"lastName\": \"One\",\n  \"email\": \"{{studentEmail}}\",\n  \"password\": \"{{studentPassword}}\",\n  \"nationalId\": \"{{studentNationalId}}\",\n  \"role\": \"STUDENT\"\n}"
            },
            "url": "{{baseUrl}}/api/register"
          }
        },
        {
          "name": "Verify Register OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "pm.test('OTP verify success', function () {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{studentEmail}}\",\n  \"otp\": \"{{registerOtp}}\"\n}"
            },
            "url": "{{baseUrl}}/api/register/verify"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  if (pm.request.body.raw.includes('admin')) {",
                  "    pm.collectionVariables.set('adminToken', json.token);",
                  "  } else {",
                  "    pm.collectionVariables.set('studentToken', json.token);",
                  "    pm.collectionVariables.set('token', json.token);",
                  "  }",
                  "}",
                  "if (json.user && json.user.id) pm.collectionVariables.set('userId', json.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/api/login"
          }
        },
